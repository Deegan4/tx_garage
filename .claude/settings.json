{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start.sh",
            "statusMessage": "Loading project context..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/sql-guard.sh",
            "statusMessage": "Scanning for SQL injection patterns..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/nui-check.sh",
            "statusMessage": "Checking NUI callback consistency..."
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/escrow-warn.sh",
            "statusMessage": "Checking Tebex escrow status..."
          }
        ]
      }
    ]
  }
}
